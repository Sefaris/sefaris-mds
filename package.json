{
  "name": "g3-sefaris-modmanager",
  "description": "Mod manager for Gothic 3 by Sefaris",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "author": {
    "email": "gothicsefaris@gmail.com",
    "name": "Sefaris",
    "url": "https://sefaris.eu"
  },
  "main": "packages/main/dist/index.cjs",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "cd ./packages/main && vite build",
    "build:preload": "cd ./packages/preload && vite build",
    "build:renderer": "cd ./packages/renderer && vite build",
    "compile": "cross-env MODE=DEBUG npm run build && electron-builder build --config .electron-builder.config.cjs --dir --config.asar=true",
    "test": "npm run test:main && npm run test:preload && npm run test:renderer && npm run test:e2e",
    "test:e2e": "npm run build && vitest run",
    "test:main": "vitest run -r packages/main --passWithNoTests",
    "test:preload": "vitest run -r packages/preload --passWithNoTests",
    "test:renderer": "vitest run -r packages/renderer --passWithNoTests",
    "watch": "node --no-deprecation scripts/watch.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck:main": "tsc --noEmit -p packages/main/tsconfig.json",
    "typecheck:preload": "tsc --noEmit -p packages/preload/tsconfig.json",
    "typecheck:renderer": "vue-tsc --noEmit -p packages/renderer/tsconfig.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "postinstall": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/update-electron-vendors.mjs",
    "format": "npx prettier --write \"**/*.{js,mjs,cjs,ts,mts,cts,vue,json}\"",
    "packages:check": "ncu",
    "packages:update": "ncu --upgrade"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/he": "^1.2.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/winreg": "^1.2.36",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "memfs": "^4.57.2",
    "nano-staged": "^1.0.2",
    "npm-check-updates": "^21.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.99.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@mdi/font": "^7.4.47",
    "electron-updater": "^6.8.3",
    "flag-icons": "^7.5.0",
    "he": "^1.2.0",
    "markdown-it": "^14.1.1",
    "markdown-it-color-plus": "^0.0.1",
    "pinia": "^3.0.4",
    "tailwind-scrollbar": "^4.0.2",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4",
    "winreg": "^1.2.5",
    "winston": "^3.19.0"
  }
}
